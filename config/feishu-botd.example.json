{
  "feishu": {
    "app_id": "cli_xxx",
    "app_secret": "replace-me"
  },
  "listeners": {
    "http_socket": "/run/feishu-botd/feishu-botd.sock",
    "http_bind": "0.0.0.0:7345",
    "auth_token_file": "/run/secrets/feishu-botd-token",
    "allow_non_loopback_bind": true
  },
  "commands": {
    "enabled": false,
    "bot_open_id": "ou_xxx",
    "bot_user_id": "",
    "bot_union_id": "",
    "bot_names": ["Feishu Bot"],
    "scripts": {
      "enabled": false,
      "command": "pls",
      "dir": "/etc/feishu-botd/scripts",
      "allowed_chats": ["ci"],
      "timeout_seconds": 300
    }
  },
  "channels": {
    "ci": "oc_xxx",
    "ops": "oc_yyy"
  },
  "default_channel": "ops",
  "services": {
    "jenkins": {
      "default_channel": "ci"
    },
    "manual": {
      "default_channel": "ops"
    }
  },
  "dedupe_ttl_seconds": 21600,
  "send_timeout_seconds": 15
}
