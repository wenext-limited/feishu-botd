# Copy this file to .env and fill in real values before running docker compose.

FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=replace-me

# Alias-to-chat-id mappings. Callers send to target.channel = "ci".
FEISHU_BOTD_CHANNELS=ci=oc_xxx

# Bind the host port to a specific LAN IP when possible, for example:
# FEISHU_BOTD_HOST_IP=192.168.1.10
FEISHU_BOTD_HOST_IP=0.0.0.0

FEISHU_BOTD_DEDUPE_TTL_SECONDS=21600
FEISHU_BOTD_SEND_TIMEOUT_SECONDS=15
